#!/usr/bin/env python3
import argparse
import datetime as dt
import os
import pathlib
import pty
import re
import shlex
import shutil
import subprocess
import sys
from typing import List, Optional

APP_DIR = pathlib.Path(os.environ.get("SERVICE_GONGBANG_STATE", "~/.service-gongbang")).expanduser()
SESSIONS_DIR = APP_DIR / "sessions"
LATEST_LINK = APP_DIR / "latest"
ANSI_RE = re.compile(r"\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])")


def ensure_state() -> None:
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)


def now_id() -> str:
    return dt.datetime.now().strftime("%Y%m%d-%H%M%S")


def set_latest(path: pathlib.Path) -> None:
    ensure_state()
    try:
        if LATEST_LINK.exists() or LATEST_LINK.is_symlink():
            LATEST_LINK.unlink()
        LATEST_LINK.symlink_to(path)
    except OSError:
        (APP_DIR / "latest.txt").write_text(str(path), encoding="utf-8")


def resolve_session(raw: Optional[str]) -> pathlib.Path:
    if raw:
        candidate = pathlib.Path(raw).expanduser()
        if candidate.exists():
            return candidate
        candidate = SESSIONS_DIR / f"{raw}.log"
        if candidate.exists():
            return candidate
        raise SystemExit(f"session not found: {raw}")

    if LATEST_LINK.exists() or LATEST_LINK.is_symlink():
        return LATEST_LINK.resolve()

    fallback = APP_DIR / "latest.txt"
    if fallback.exists():
        return pathlib.Path(fallback.read_text(encoding="utf-8").strip()).expanduser()

    raise SystemExit("no transcript yet. Start one with: gongbang run <command>")


def command_display(command: List[str]) -> str:
    return " ".join(shlex.quote(part) for part in command)


def cmd_run(args: argparse.Namespace) -> int:
    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        raise SystemExit("usage: gongbang run <command> [args...]")

    ensure_state()
    session_name = args.name or now_id()
    log_path = SESSIONS_DIR / f"{session_name}.log"
    set_latest(log_path)

    started = dt.datetime.now().isoformat(timespec="seconds")
    header = f"\n[gongbang] session={session_name} started={started} command={command_display(command)}\n\n"

    with log_path.open("ab") as log:
        log.write(header.encode("utf-8"))
        log.flush()

        def master_read(fd: int) -> bytes:
            data = os.read(fd, 4096)
            if data:
                log.write(data)
                log.flush()
            return data

        print(f"[gongbang] transcript: {log_path}", file=sys.stderr)
        print("[gongbang] side question: gongbang side \"여기에 질문\"", file=sys.stderr)
        status = pty.spawn(command, master_read=master_read)

        finished = dt.datetime.now().isoformat(timespec="seconds")
        footer = f"\n\n[gongbang] finished={finished} status={status}\n"
        log.write(footer.encode("utf-8"))
        log.flush()

    if hasattr(os, "waitstatus_to_exitcode"):
        return os.waitstatus_to_exitcode(status)
    return status >> 8


def clean_transcript(text: str) -> str:
    text = ANSI_RE.sub("", text)
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    lines = [line.rstrip() for line in text.splitlines()]
    return "\n".join(lines).strip()


def read_context(path: pathlib.Path, limit: int) -> str:
    raw = path.read_text(encoding="utf-8", errors="replace")
    cleaned = clean_transcript(raw)
    if len(cleaned) <= limit:
        return cleaned
    return cleaned[-limit:]


def build_prompt(question: str, transcript_path: pathlib.Path, context: str) -> str:
    return f"""You are 곁질문, a side-channel explainer for an active AI work session.

Answer the user's question without changing, steering, or interrupting the main session.
Use the transcript excerpt only as context. If the excerpt is insufficient, say what is missing.
Be concise. Answer in Korean unless the user clearly asks for another language.

Transcript: {transcript_path}

--- transcript excerpt ---
{context}
--- end excerpt ---

Question:
{question}
"""


def backend_from_args(args: argparse.Namespace) -> str:
    if args.backend != "auto":
        return args.backend

    env_backend = os.environ.get("SERVICE_GONGBANG_SIDE_BACKEND")
    if env_backend:
        return env_backend

    for name in ("claude", "codex", "gemini"):
        if shutil.which(name):
            return name

    raise SystemExit("no side-question backend found. Install claude, codex, or gemini, or use --dry-run.")


def run_backend(backend: str, prompt: str) -> int:
    custom = os.environ.get("SERVICE_GONGBANG_SIDE_COMMAND")
    if custom:
        if "{prompt}" in custom:
            return subprocess.call(custom.replace("{prompt}", shlex.quote(prompt)), shell=True)
        return subprocess.run(shlex.split(custom), input=prompt, text=True).returncode

    if backend == "claude":
        exe = shutil.which("claude") or "claude"
        return subprocess.call([exe, "-p", "--output-format", "text", prompt])

    if backend == "codex":
        exe = shutil.which("codex") or "codex"
        return subprocess.run(
            [exe, "exec", "--skip-git-repo-check", "-s", "read-only", "-"],
            input=prompt,
            text=True,
        ).returncode

    if backend == "gemini":
        exe = shutil.which("gemini") or "gemini"
        return subprocess.call([exe, "-p", prompt])

    raise SystemExit(f"unknown backend: {backend}")


def cmd_side(args: argparse.Namespace) -> int:
    question = " ".join(args.question).strip()
    if not question and not sys.stdin.isatty():
        question = sys.stdin.read().strip()
    if not question:
        raise SystemExit("usage: gongbang side <question>")

    transcript_path = resolve_session(args.session)
    context = read_context(transcript_path, args.chars)
    prompt = build_prompt(question, transcript_path, context)

    if args.dry_run:
        print(prompt)
        return 0

    backend = backend_from_args(args)
    print(f"[gongbang] side backend: {backend}", file=sys.stderr)
    print(f"[gongbang] transcript: {transcript_path}", file=sys.stderr)
    return run_backend(backend, prompt)


def cmd_sessions(_: argparse.Namespace) -> int:
    ensure_state()
    paths = sorted(SESSIONS_DIR.glob("*.log"), key=lambda p: p.stat().st_mtime, reverse=True)
    for path in paths[:20]:
        size = path.stat().st_size
        marker = " latest" if (LATEST_LINK.exists() and LATEST_LINK.resolve() == path.resolve()) else ""
        print(f"{path.stem}\t{size} bytes\t{path}{marker}")
    return 0


def cmd_latest(_: argparse.Namespace) -> int:
    print(resolve_session(None))
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="gongbang",
        description="서비스공방 CLI: run AI tools with transcripts and ask side questions.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    run_p = sub.add_parser("run", help="run a command and record its terminal transcript")
    run_p.add_argument("-n", "--name", help="session name, defaults to timestamp")
    run_p.add_argument("command", nargs=argparse.REMAINDER)
    run_p.set_defaults(func=cmd_run)

    side_p = sub.add_parser("side", aliases=["ask"], help="ask a side question against the latest transcript")
    side_p.add_argument("-s", "--session", help="session id or transcript path")
    side_p.add_argument("--chars", type=int, default=12000, help="transcript characters to include")
    side_p.add_argument("--backend", choices=["auto", "claude", "codex", "gemini"], default="auto")
    side_p.add_argument("--dry-run", action="store_true", help="print the side-question prompt without calling a model")
    side_p.add_argument("question", nargs="*")
    side_p.set_defaults(func=cmd_side)

    sessions_p = sub.add_parser("sessions", help="list recent transcript sessions")
    sessions_p.set_defaults(func=cmd_sessions)

    latest_p = sub.add_parser("latest", help="print the latest transcript path")
    latest_p.set_defaults(func=cmd_latest)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
